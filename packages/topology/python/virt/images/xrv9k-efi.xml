<domain type='kvm'>
  <name>${device-name}</name>
  <memory unit='MiB'>${memory}</memory>
  <currentMemory unit='MiB'>${memory}</currentMemory>
  <vcpu placement='static'>${vcpus}</vcpu>
  <cpu mode='host-passthrough' check='none' migratable='on'>
    <topology sockets='1' dies='1' cores='${vcpus}' threads='1'/>
  </cpu>
  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
    <boot dev='hd'/>
    <loader readonly='yes' type='pflash' stateless='no'>/usr/share/edk2/ovmf/iosxrv9000/efi_code.fd</loader>
    <nvram template='/usr/share/edk2/ovmf/iosxrv9000/efi_vars.fd'>/var/lib/libvirt/qemu/nvram/${device-name}_VARS.fd</nvram>
  </os>
  <features>
    <acpi/>
    <apic/>
  </features>
  <clock offset='utc'>
    <timer name='rtc' tickpolicy='catchup'/>
    <timer name='pit' tickpolicy='delay'/>
    <timer name='hpet' present='no'/>
  </clock>
  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>
  <pm>
    <suspend-to-mem enabled='no'/>
    <suspend-to-disk enabled='no'/>
  </pm>
  <devices>
    <emulator>/usr/bin/qemu-system-x86_64</emulator>

    <!-- Access: XR Console -->
    <serial type='tcp'>
       <source mode="bind" host="0.0.0.0" service="160${id}"/>
       <protocol type="telnet"/>
       <target port="0"/>
    </serial>
    <!-- Access: XR Aux (telnet localhost 16101) -->
    <serial type='tcp'>
       <source mode="bind" host="0.0.0.0" service="161${id}"/>
       <protocol type="telnet"/>
       <target port="1"/>
    </serial>
    <!-- Access: Admin / Calvados (telnet localhost 16201) -->
    <serial type='tcp'>
       <source mode="bind" host="0.0.0.0" service="162${id}"/>
       <protocol type="telnet"/>
       <target port="2"/>
    </serial>
    <!-- Access: HOST VM (telnet localhost 16301) -->
    <serial type='tcp'>
       <source mode="bind" host="0.0.0.0" service="163${id}"/>
       <protocol type="telnet"/>
       <target port="3"/>
    </serial>

  </devices>
</domain>

